{
  "name": "foldx",
  "displayName": "FoldX",
  "description": "Fold matching function calls in the current file.",
  "version": "0.4.0",
  "publisher": "Peckage",
  "icon": "icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Peckage/FoldX"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "fold",
    "collapse",
    "function",
    "calls",
    "test",
    "it",
    "describe"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "foldx.foldByFunctionName",
        "title": "FoldX: Fold by Function Name"
      },
      {
        "command": "foldx.unfoldAll",
        "title": "FoldX: Unfold All"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "foldx.foldByFunctionName",
          "when": "editorLangId =~ /typescript|typescriptreact|javascript|javascriptreact/",
          "group": "1_modification@99"
        }
      ]
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify",
    "build:types": "tsc",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "vsce package --no-dependencies",
    "vscode:prepublish": "pnpm run build"
  },
  "dependencies": {
    "typescript": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.28.0",
    "vitest": "^1.2.0"
  }
}
